# 行尾与文本属性规范化
# 保证跨平台（Windows / macOS / Linux）检出时文本文件一致
* text=auto eol=lf

*.py    text
*.js    text
*.css   text
*.html  text
*.md    text
*.json  text
*.yml   text
*.yaml  text
*.sql   text
*.bat   text eol=crlf

# 二进制文件明确标记为 -text，避免被 Git 误当做文本处理
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.bin   binary
*.sqlite3 binary
*.db    binary
